#include <stdio.h>

struct p {
    int at, bt, pr, rt, ct, wt, tat;
} p[20];

int main() {
    int n, time = 0, done = 0;
    float awt = 0, atat = 0;

    printf("Enter n: ");
    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        printf("AT BT PR P%d: ", i+1);
        scanf("%d%d%d", &p[i].at, &p[i].bt, &p[i].pr);
        p[i].rt = p[i].bt;
    }

    while(done < n) {
        int idx = -1, minp = 9999;

        for(int i = 0; i < n; i++) {
            if(p[i].at <= time && p[i].rt > 0) {
                if(p[i].pr < minp) {
                    minp = p[i].pr;
                    idx = i;
                }
            }
        }

        if(idx != -1) {
            p[idx].rt--;
            time++;

            if(p[idx].rt == 0) {
                done++;
                p[idx].ct = time;
                p[idx].tat = p[idx].ct - p[idx].at;
                p[idx].wt = p[idx].tat - p[idx].bt;
            }
        } else {
            time++; // CPU idle
        }
    }

    printf("\nP\tCT\tWT\tTAT\n");
    for(int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\n", i+1, p[i].ct, p[i].wt, p[i].tat);
        awt += p[i].wt;
        atat += p[i].tat;
    }

    printf("\nAvg WT=%.2f\nAvg TAT=%.2f\n", awt/n, atat/n);

    return 0;
}
