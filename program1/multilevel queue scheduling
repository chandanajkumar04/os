#include <stdio.h>

struct p {
    int at, bt, rt, q, ct, wt, tat;
} p[20];

int main() {
    int n, tq;
    float awt = 0, atat = 0, time = 0;

    printf("Enter n: ");
    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        printf("AT BT Q(1/2/3) P%d: ", i+1);
        scanf("%d%d%d", &p[i].at, &p[i].bt, &p[i].q);
        p[i].rt = p[i].bt;
    }

    printf("TQ: ");
    scanf("%d", &tq);

    
    for(int q = 1; q <= 2; q++) {
        int done;
        do {
            done = 1;
            for(int i = 0; i < n; i++) {
                if(p[i].q == q && p[i].rt > 0 && p[i].at <= time) {
                    done = 0;
                    if(p[i].rt > tq) {
                        time += tq;
                        p[i].rt -= tq;
                    } else {
                        time += p[i].rt;
                        p[i].ct = time;
                        p[i].tat = p[i].ct - p[i].at;
                        p[i].wt = p[i].tat - p[i].bt;
                        p[i].rt = 0;
                    }
                }
            }
        } while(!done);
    }

    for(int i = 0; i < n; i++) {
        if(p[i].q == 3) {
            if(time < p[i].at) time = p[i].at;
            time += p[i].bt;
            p[i].ct = time;
            p[i].tat = p[i].ct - p[i].at;
            p[i].wt = p[i].tat - p[i].bt;
        }
    }

    printf("\nP\tCT\tWT\tTAT\n");
    for(int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\n", i+1, p[i].ct, p[i].wt, p[i].tat);
        awt += p[i].wt;
        atat += p[i].tat;
    }

    printf("\nAvg WT=%.2f\nAvg TAT=%.2f\n", awt/n, atat/n);
    return 0;
}
