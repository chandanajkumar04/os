#include <stdio.h>

int main() {
    int n, m, i, j, k;

    printf("Enter processes and resources: ");
    scanf("%d %d", &n, &m);

    int alloc[n][m], req[n][m], avail[m], finish[n];

    printf("Enter Allocation Matrix:\n");
    for(i = 0; i < n; i++)
        for(j = 0; j < m; j++)
            scanf("%d", &alloc[i][j]);

    printf("Enter Request Matrix:\n");
    for(i = 0; i < n; i++)
        for(j = 0; j < m; j++)
            scanf("%d", &req[i][j]);

    printf("Enter Available Resources:\n");
    for(i = 0; i < m; i++)
        scanf("%d", &avail[i]);

    for(i = 0; i < n; i++)
        finish[i] = 0;

  
    for(k = 0; k < n; k++) {
        for(i = 0; i < n; i++) {

            if(finish[i] == 0) {

                for(j = 0; j < m; j++) {
                    if(req[i][j] > avail[j])
                        break;
                }

                if(j == m) {
                    for(j = 0; j < m; j++)
                        avail[j] += alloc[i][j];

                    finish[i] = 1;
                }
            }
        }
    }

    int deadlock = 0;

    printf("Deadlocked Processes: ");

    for(i = 0; i < n; i++) {
        if(finish[i] == 0) {
            printf("P%d ", i);
            deadlock = 1;
        }
    }

    if(deadlock == 0)
        printf("None");

    return 0;
}
